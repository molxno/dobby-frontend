#!/bin/bash
# Pre-push hook: prevent direct push to main
# All changes must go through PRs from feature branches -> dev -> main

remote="$1"

while read local_ref local_sha remote_ref remote_sha; do
  if echo "$remote_ref" | grep -qE "refs/heads/main$"; then
    echo ""
    echo "ERROR: Direct push to main is not allowed."
    echo ""
    echo "Project gitflow:"
    echo "  1. Create a branch from dev: git checkout -b feat/my-feature dev"
    echo "  2. Make your commits"
    echo "  3. Push your branch: git push -u origin feat/my-feature"
    echo "  4. Create a PR to dev"
    echo "  5. After review, merge to dev"
    echo "  6. For release: create a PR from dev -> main"
    echo ""
    exit 1
  fi
done

exit 0
