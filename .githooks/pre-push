#!/bin/bash
# Pre-push hook: prevent direct push to main
# All changes must go through PRs from feature branches -> dev -> main

remote="$1"

while read local_ref local_sha remote_ref remote_sha; do
  if echo "$remote_ref" | grep -qE "refs/heads/main$"; then
    echo ""
    echo "ERROR: Push directo a main no está permitido."
    echo ""
    echo "Gitflow del proyecto:"
    echo "  1. Crea una rama desde dev: git checkout -b feat/mi-feature dev"
    echo "  2. Haz tus commits"
    echo "  3. Push tu rama: git push -u origin feat/mi-feature"
    echo "  4. Crea un PR hacia dev"
    echo "  5. Después de review, merge a dev"
    echo "  6. Para release: crea PR de dev -> main"
    echo ""
    exit 1
  fi
done

exit 0
